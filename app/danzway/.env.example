# Copy this file to .env.local and fill in your values.

# ── Firebase ─────────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Google Maps & Places ──────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
# Enable: Maps JavaScript API + Places API (New)
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_PLACES_API_KEY=
# Map ID for the interactive map (enables AdvancedMarkers + cloud styling)
# Create one at: Google Cloud Console → Map Management → Create Map ID
# Leave empty to use DEMO_MAP_ID (localhost only)
VITE_GOOGLE_MAP_ID=

# ── Admin (never commit as true) ─────────────────────────────────────────────
# Set VITE_IS_ADMIN=true in your LOCAL .env.local only — never commit this value
# VITE_IS_ADMIN=true
